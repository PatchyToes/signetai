# Public hostname served by Caddy (TLS is automatic for real domains)
SIGNET_DOMAIN=localhost

# Published image tag
SIGNET_IMAGE_TAG=latest

# Host ports for the reverse proxy
SIGNET_HTTP_PORT=80
SIGNET_HTTPS_PORT=443

# Optional external provider credentials for memory extraction
OPENAI_API_KEY=
OPENROUTER_API_KEY=

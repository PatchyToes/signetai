---
const features = [
  {
    title: 'Distillation, Not Storage',
    description: 'A local LLM reviews every session and distills it into structured insights — no tool calls, no agent involvement. It checks against existing knowledge and decides: new, update, replace, or skip. Your agent won\'t store the same thing twice.',
    symbol: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="12" r="4"/><path d="M12 4v4M12 16v4M4 12h4M16 12h4"/></svg>',
  },
  {
    title: 'Knowledge Graph',
    description: 'Named entities — people, projects, tools — are extracted and linked. When you ask about a project, Signet traverses the graph: architecture, people, dependencies, constraints. Context arrives structured, not as fragments.',
    symbol: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>',
  },
  {
    title: 'Secrets & Trust',
    description: 'Secrets are libsodium-encrypted at rest. Your agent can use them without reading their values — Signet injects into subprocess environments and redacts from output. Nothing leaves your machine unless you configure it to.',
    symbol: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><rect x="5" y="10" width="14" height="10"/><path d="M8 10V7a4 4 0 018 0v3"/></svg>',
  },
  {
    title: 'One Agent, Every Platform',
    description: 'The same agent follows you across Claude Code, OpenCode, and OpenClaw. Same personality, same knowledge, same secrets. Switch tools without starting over. Signet is the home directory.',
    symbol: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"><path d="M4 4h4v4H4zm6 0h4v4h-4zm6 0h4v4h-4zM4 10h4v4H4zm6 0h4v4h-4zm6 0h4v4h-4zM4 16h4v4H4zm6 0h4v4h-4zm6 0h4v4h-4z"/></svg>',
  },
];
---

<section id="what-it-does" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">What It Does</span>
    <span class="section-index">03 / 07</span>
  </div>

  <div class="features-showcase reveal">
    {features.map((feature, i) => (
      <div class="feature-module">
        <div class="feature-module-barcode" aria-hidden="true"></div>
        <div class="feature-module-body">
          <div class="feature-schematic">
            <span class="feature-symbol" aria-hidden="true" set:html={feature.symbol}></span>
            <div class="schematic-crosshair top-left"></div>
            <div class="schematic-crosshair bottom-right"></div>
          </div>
          <div class="feature-content">
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-desc">{feature.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
